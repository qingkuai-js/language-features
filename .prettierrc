{
    "tabWidth": 4,
    "semi": false,
    "printWidth": 100,
    "arrowParens": "avoid",
    "trailingComma": "none",
    "overrides": [
        {
            "files": ["*.yaml"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["regular.ts", "**/*.d.ts"],
            "options": {
                "printWidth": 200
            }
        }
    ]
}
