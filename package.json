{
    "name": "qingkuai-language-features",
    "packageManager": "pnpm@8.7.6",
    "version": "1.0.0",
    "author": "lgq",
    "private": true,
    "scripts": {
        "dev": "rollup -c -w",
        "build": "pnpm run build:clean && pnpm run build:language-service-types && pnpm run build:bundle && pnpm run build:post",
        "build:clean": "rimraf packages/language-service/dist packages/mcp-server/dist",
        "build:language-service-types": "cd ./packages/language-service && tsc -p tsconfig.dts.json",
        "build:bundle": "node ./scripts/export-raw.js && rollup -c",
        "build:post": "rimraf packages/language-service/dist/temp-types"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^26.0.3",
        "@rollup/plugin-node-resolve": "^15.3.1",
        "@types/node": "^22.13.8",
        "@types/vscode": "^1.97.0",
        "@vscode/emmet-helper": "^2.11.0",
        "fs-extra": "^11.3.4",
        "prettier": "^3.8.1",
        "qingkuai": "^1.0.52",
        "rimraf": "^6.0.1",
        "rollup": "^4.34.9",
        "rollup-plugin-dts": "^6.2.1",
        "rollup-plugin-esbuild": "^6.2.1",
        "tsx": "^4.21.0",
        "typescript": "^5.8.2",
        "vitest": "^2.1.9",
        "vscode-jsonrpc": "^8.2.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12",
        "vscode-languageserver-types": "^3.17.5"
    },
    "pnpm": {
        "patchedDependencies": {
            "emmet": "patches/emmet.patch"
        }
    }
}
