{
    "name": "qingkuai-language-features",
    "version": "1.0.11",
    "author": "lgq",
    "license": "MIT",
    "displayName": "QingKuai",
    "icon": "imgs/qingkuai.png",
    "publisher": "qingkuai-tools",
    "description": "qingkuai language support for vscode",
    "main": "./dist/client.js",
    "engines": {
        "vscode": "^1.93.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:qingkuai",
        "onLanguage:javascript",
        "onLanguage:typescript",
        "workspaceContains:**/*.qk"
    ],
    "contributes": {
        "mcpServerDefinitionProviders": [
            {
                "id": "qingkuai-tools.qingkuai-mcp-server",
                "label": "QingKuai MCP Server"
            }
        ],
        "commands": [
            {
                "command": "qingkuai.restartLanguageServer",
                "title": "Restart Language Server",
                "category": "Qingkuai"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "qingkuai.restartLanguageServer",
                    "when": "resourceFilename =~ /\\.(?:qk|qingkuairc)/"
                }
            ]
        },
        "languages": [
            {
                "id": "qingkuai-emmet",
                "aliases": [
                    "qke"
                ]
            },
            {
                "id": "qingkuai",
                "extensions": [
                    ".qk"
                ],
                "aliases": [
                    "QingKuai",
                    "qk"
                ],
                "icon": {
                    "light": "./imgs/qingkuai.png",
                    "dark": "./imgs/qingkuai.png"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "qingkuai-markdown-injection"
            }
        ],
        "grammars": [
            {
                "language": "qingkuai",
                "scopeName": "source.qk",
                "path": "./syntaxes/qingkuai.tmLanguage.json",
                "embeddedLanguages": {
                    "source.jsdoc": "jsdoc",
                    "source.js": "javascript",
                    "source.ts": "typescript",
                    "source.css": "css",
                    "source.sass": "sass",
                    "source.stylus": "stylus",
                    "source.css.scss": "scss",
                    "source.css.less": "less",
                    "source.css.postcss": "css",
                    "text.html.markdown": "markdown"
                },
                "unbalancedBracketScopes": [
                    "text",
                    "text-content.qk",
                    "entity.name.tag",
                    "punctuation.definition.tag",
                    "storage.type.function.arrow",
                    "keyword.operator.relational",
                    "keyword.operator.bitwise.shift"
                ]
            },
            {
                "language": "qingkuai-emmet",
                "scopeName": "source.qke",
                "path": "./syntaxes/qingkuai-emmet.tmLanguage.json",
                "embeddedLanguages": {
                    "source.qk": "qingkuai"
                }
            },
            {
                "scopeName": "source.css.postcss",
                "path": "./syntaxes/postcss.tmLanguage.json"
            },
            {
                "language": "qingkuai-markdown-injection",
                "scopeName": "markdown.qingkuai.codeblock",
                "path": "./syntaxes/qingkuai-markdown-injection.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "source.tsx.embedded.qingkuai": "qingkuai"
                }
            }
        ],
        "typescriptServerPlugins": [
            {
                "name": "typescript-plugin-qingkuai",
                "enableForWorkspaceTypeScriptVersions": true
            }
        ],
        "jsonValidation": [
            {
                "fileMatch": ".qingkuairc",
                "url": "./qingkuairc-schema.json"
            },
            {
                "fileMatch": ".prettierrc",
                "url": "./qingkuai-prettierrc-schema.json"
            }
        ],
        "configurationDefaults": {
            "files.associations": {
                ".qingkuairc": "json",
                ".prettierrc": "json"
            }
        },
        "configuration": {
            "title": "QingKuai",
            "properties": {
                "qingkuai.typescriptDiagnosticsExplain": {
                    "type": "boolean",
                    "default": true,
                    "description": "Add explanations to ambiguous TypeScript diagnostics in QingKuai files.",
                    "markdownDescription": "Controls whether **ambiguous TypeScript diagnostic messages** in `.qk` files include additional explanations to help you understand the issue."
                },
                "qingkuai.insertSpaceAroundInterpolation": {
                    "type": "boolean",
                    "default": false,
                    "description": "Insert spaces around interpolation blocks.",
                    "markdownDescription": "Controls whether spaces are inserted **around interpolation blocks** in templates.\n\nInterpolation blocks use **single curly braces `{ }`**."
                },
                "qingkuai.componentTagFormatPreference": {
                    "type": "string",
                    "enum": [
                        "camel",
                        "kebab"
                    ],
                    "default": "camel",
                    "description": "Preferred component tag format for formatting and completion suggestions.",
                    "markdownEnumDescriptions": [
                        "Prefer **camelCase** for component tags.\n\nExample:\n```qingkuai\n<MyComponent></MyComponent>\n```",
                        "Prefer **kebab-case** for component tags.\n\nExample:\n```qingkuai\n<my-component></my-component>\n```"
                    ]
                },
                "qingkuai.componentAttributeFormatPreference": {
                    "type": "string",
                    "enum": [
                        "camel",
                        "kebab"
                    ],
                    "default": "camel",
                    "description": "Preferred component attribute format for formatting and completion suggestions.",
                    "markdownEnumDescriptions": [
                        "Prefer **camelCase** for component attributes.\n\nExample:\n```qingkuai\n<MyComponent myCustomAttribute />\n```",
                        "Prefer **kebab-case** for component attributes.\n\nExample:\n```qingkuai\n<MyComponent my-custom-attribute />\n```"
                    ]
                },
                "qingkuai.htmlHoverTip": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "tag",
                            "entity",
                            "attribute"
                        ]
                    },
                    "default": [
                        "tag",
                        "entity",
                        "attribute"
                    ],
                    "uniqueItems": true
                },
                "qingkuai.additionalCodeLens": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "slot",
                            "component"
                        ]
                    },
                    "default": [
                        "slot",
                        "component"
                    ],
                    "uniqueItems": true,
                    "description": "Additional code lenses to enable if [embeddedScriptLanguageId].referencesCodeLens is enabled.",
                    "markdownDescription": "Controls which **additional code lenses** are enabled in `.qk` files.\n\nThis only works if `javascript/typescript.referencesCodeLens.enabled` (or JavaScript equivalent) is true."
                },
                "qingkuai.hoverTipReactiveStatus": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable hover tips showing the inferred reactivity state of variables.",
                    "markdownDescription": "Controls whether hovering over variables in `.qk` templates shows the **compiler-inferred reactivity status.\n\nThis is useful for understanding how variables are tracked and updated by Qingkuai."
                }
            }
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/qingkuai-js/language-features.git",
        "directory": "packages/vscode-extension"
    },
    "scripts": {
        "build:grammars": "npm run build:grammar && npm run build:emmet-grammar",
        "build:grammar": "cd ./syntaxes/src && npx js-yaml ./qingkuai.tmLanguage.yaml > ../qingkuai.tmLanguage.json && npx prettier --write ../qingkuai.tmLanguage.json",
        "build:emmet-grammar": "cd ./syntaxes/src && npx js-yaml ./qingkuai-emmet.tmLanguage.yaml > ../qingkuai-emmet.tmLanguage.json && npx prettier --write ../qingkuai-emmet.tmLanguage.json",
        "vsce:local-package": "tsx ./scripts/build-with-local.ts package",
        "vsce:local-publish": "tsx ./scripts/build-with-local.ts publish",
        "vsce:post": "cd ../../ && rimraf --glob '**/package-lock.json' && rimraf --glob '**/node_modules' && pnpm install",
        "vsce:ls": "npm run vsce:pre && cd ../../ && npm run build && cd ./packages/vscode-extension && vsce ls && vsce:post",
        "vsce:publish": "npm run vsce:pre && cd ../../ && npm run build && cd ./packages/vscode-extension && vsce publish && npm run vsce:post",
        "vsce:package": "npm run vsce:pre && cd ../../ && npm run build && cd ./packages/vscode-extension && vsce package && npm run vsce:post",
        "vsce:pre": "cd ../../ && rimraf --glob 'packages/*/node_modules' && cd ./packages/vscode-extension && npm install && cd ../typescript-plugin && npm install && cd ../language-service && npm install && cd ../language-server && npm install && cd ../mcp-server && npm install"
    },
    "devDependencies": {
        "js-yaml": "^4.1.0",
        "vsce": "^2.15.0"
    },
    "dependencies": {
        "prettier-plugin-qingkuai": "^1.0.31",
        "qingkuai": "^1.0.52",
        "qingkuai-mcp-server": "file:../mcp-server",
        "typescript-plugin-qingkuai": "file:../typescript-plugin",
        "vscode-css-languageservice": "^6.3.10",
        "vscode-languageclient": "^9.0.1",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12",
        "vscode-languageserver-types": "^3.17.5"
    }
}
