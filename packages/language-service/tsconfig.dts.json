{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "declaration": true,
        "module": "ESNext",
        "skipLibCheck": true,
        "rootDir": "../..",
        "outDir": "./dist/temp-types",
        "emitDeclarationOnly": true,
        "skipDefaultLibCheck": true,
        "moduleResolution": "Bundler",
        "forceConsistentCasingInFileNames": true,
        "types": ["node"]
    },
    "include": ["src/**/*"]
}
