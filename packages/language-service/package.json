{
    "name": "qingkuai-language-service",
    "license": "MIT",
    "author": "mlgq",
    "type": "module",
    "version": "1.0.17",
    "keywords": [
        "qingkuai",
        "language-service"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./adapters": {
            "types": "./dist/adapters.d.ts",
            "import": "./dist/adapters.js",
            "require": "./dist/adapters.cjs"
        },
        "./grammars/qingkuai": "./grammars/qingkuai.tmLanguage.json",
        "./grammars/qingkuai-emmet": "./grammars/qingkuai-emmet.tmLanguage.json"
    },
    "publishConfig": {
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.js",
                "require": "./dist/index.cjs"
            },
            "./adapters": {
                "types": "./dist/adapters.d.ts",
                "import": "./dist/adapters.js",
                "require": "./dist/adapters.cjs"
            },
            "./grammars/qingkuai": "./grammars/qingkuai.tmLanguage.json",
            "./grammars/qingkuai-emmet": "./grammars/qingkuai-emmet.tmLanguage.json"
        }
    },
    "scripts": {
        "postpublish": "curl -X PUT 'https://registry-direct.npmmirror.com/-/package/qingkuai-language-service/syncs'"
    },
    "peerDependencies": {
        "qingkuai": "catalog:"
    },
    "dependencies": {
        "strip-ansi": "^7.2.0",
        "vscode-css-languageservice": "^6.3.10",
        "vscode-languageserver-types": "catalog:",
        "vscode-uri": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@vscode/emmet-helper": "catalog:",
        "qingkuai": "catalog:",
        "vscode-languageserver": "catalog:",
        "vscode-languageserver-textdocument": "catalog:"
    },
    "description": "The language service for qingkuai"
}
