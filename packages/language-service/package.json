{
    "name": "qingkuai-language-service",
    "license": "MIT",
    "author": "mlgq",
    "version": "1.0.15",
    "keywords": [
        "qingkuai",
        "language-service"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        },
        "./adapters": {
            "import": "./dist/adapters.js",
            "require": "./dist/adapters.cjs",
            "types": "./dist/adapters.d.ts"
        },
        "./grammars/qingkuai": "./grammars/qingkuai.tmLanguage.json",
        "./grammars/qingkuai-emmet": "./grammars/qingkuai-emmet.tmLanguage.json"
    },
    "scripts": {
        "postpublish": "curl -X PUT 'https://registry-direct.npmmirror.com/-/package/qingkuai-language-service/syncs'"
    },
    "peerDependencies": {
        "qingkuai": "^1.0.55"
    },
    "dependencies": {
        "strip-ansi": "^7.2.0",
        "vscode-css-languageservice": "^6.3.10",
        "vscode-uri": "^3.1.0"
    },
    "devDependencies": {
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12",
        "vscode-languageserver-types": "^3.17.5"
    },
    "description": "The language service for qingkuai"
}
